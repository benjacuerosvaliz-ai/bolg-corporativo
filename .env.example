# BØLG Corporativo — variables de entorno
#
# Copia este archivo a .env.local y rellena para desarrollo local.
# .env.local NO se commitea (gitignored).
#
# Para producción (Vercel), agrega cada variable en:
#   Vercel → Project → Settings → Environment Variables
#
# Las marcadas como [SECRET] NO deben exponerse en código cliente.
# Las marcadas como [PUBLIC] pueden bundlearse en el frontend.

# =============================================================================
# Shopify Storefront API — catálogo público y precios retail
# =============================================================================

# Dominio xxx.myshopify.com (no el dominio público bolg.cl)
SHOPIFY_STORE_DOMAIN=fe10b8-2.myshopify.com

# [SECRET] Storefront API access token. En .env.local: el token real.
# En Vercel: agregar como Environment Variable.
SHOPIFY_STOREFRONT_API_TOKEN=

# Versión del API. Default 2025-01.
SHOPIFY_API_VERSION=2025-01

# =============================================================================
# Shopify Admin API — stock real + draft orders
# =============================================================================

# [SECRET] Admin API access token. Empieza con `shpat_`.
# Se obtiene creando una custom app en Shopify Admin (ver docs/SHOPIFY_SETUP.md).
# Scopes requeridos: read_products, read_inventory, read_locations,
# write_draft_orders, read_orders.
SHOPIFY_ADMIN_API_TOKEN=

# =============================================================================
# Flag de mock
# =============================================================================

# true → usa lib/shopify/mock.ts (3 productos genéricos para dev sin Shopify).
# false → consulta Shopify real. Requiere metafields corporate.* configurados
# en al menos los productos taggeados CORPORATIVO. Ver docs/SHOPIFY_SETUP.md.
USE_MOCK_PRODUCTS=true

# =============================================================================
# Resend — magic link + emails transaccionales (Fase 4-5)
# =============================================================================

# [SECRET] API key de Resend. Empieza con `re_`.
# Crear en https://resend.com/api-keys
RESEND_API_KEY=

# Email FROM verificado en Resend (necesita DNS de bolg.cl).
RESEND_FROM_EMAIL=cotizaciones@bolg.cl

# Email del equipo corporativo que recibe leads y notificaciones internas.
RESEND_INTERNAL_EMAIL=corporativo@bolg.cl

# =============================================================================
# Auth — magic link signing (Fase 5)
# =============================================================================

# [SECRET] Secret para firmar JWTs cortos del magic link.
# Generar con: openssl rand -base64 32
AUTH_SECRET=

# =============================================================================
# Vercel Blob — uploads de logos de clientes (Fase 2e+)
# =============================================================================

# [SECRET] Token de Vercel Blob. Se crea desde Vercel Storage → Blob.
BLOB_READ_WRITE_TOKEN=

# =============================================================================
# Vercel KV (Redis) — cotizaciones guardadas + rate limiting (Fase 3+)
# =============================================================================

# Se crean desde Vercel Storage → KV. Vercel auto-popula estas vars
# cuando conectas el store al proyecto.
KV_REST_API_URL=
# [SECRET]
KV_REST_API_TOKEN=
# [SECRET] Para lecturas, opcional.
KV_REST_API_READ_ONLY_TOKEN=

# =============================================================================
# Analytics (Fase 7 — opcional para arrancar)
# =============================================================================

# [PUBLIC] PostHog para tracking de funnel de cotización.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# Site
# =============================================================================

# URL pública del sitio. Local dev: http://localhost:3500. Prod: https://corporativo.bolg.cl
NEXT_PUBLIC_SITE_URL=http://localhost:3500
