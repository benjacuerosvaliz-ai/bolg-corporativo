# BOLG Corporativo — variables de entorno
# Copia este archivo a .env.local y rellena los valores.
# .env.local NO se commitea (está en .gitignore).

# -----------------------------------------------------------------------------
# Shopify (obligatorio para producción, opcional en Fase 0-1 con mock)
# -----------------------------------------------------------------------------
SHOPIFY_STORE_DOMAIN=xxx.myshopify.com
SHOPIFY_STOREFRONT_API_TOKEN=
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_API_VERSION=2025-01

# Mientras los metafields corporate.* no estén configurados en Shopify,
# activar mock data para desarrollar el resto del sistema.
USE_MOCK_PRODUCTS=true

# -----------------------------------------------------------------------------
# Email + Auth (Fase 4-5)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=cotizaciones@bolg.cl
AUTH_SECRET=

# -----------------------------------------------------------------------------
# Vercel Blob + KV (Fase 2-3)
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# -----------------------------------------------------------------------------
# Analytics (Fase 7)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://corporativo.bolg.cl
